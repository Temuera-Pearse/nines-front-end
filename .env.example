# Nines frontend public configuration.
# VITE_* values are browser-visible. Do not put secrets here.

# Public launch mode for https://nines.live.
VITE_PUBLIC_VIEWER_MODE=true
VITE_AUTH_ENABLED=false

# Production race backend endpoints.
VITE_NINES_BACKEND_URL=https://example-race-api.invalid
VITE_NINES_WS_URL=wss://example-race-api.invalid/ws

# Optional legacy aliases supported by the frontend.
VITE_API_URL=
VITE_WS_URL=
VITE_WS_PATH=/ws
VITE_WS_MODE=plain
VITE_WS_BINARY=

# Local/offline development only.
VITE_OFFLINE=
VITE_API_TOKEN=
VITE_DEV_PROXY_TARGET=https://example-race-api.invalid
NINES_API_PROXY_TARGET=http://127.0.0.1:3002

# Auth0 is intentionally disabled for the public launch.
# These may be restored only with VITE_AUTH_ENABLED=true and
# VITE_PUBLIC_VIEWER_MODE=false in a future private deployment.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_NINES_API_URL=
