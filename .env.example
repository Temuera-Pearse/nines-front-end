# Frontend runtime config (Vite)
#
# By default, this app uses the Vite dev proxy:
#   HTTP  -> /race, /bets, /health (and /api) -> VITE_DEV_PROXY_TARGET
#   WS    -> /ws   -> VITE_DEV_PROXY_TARGET (ws)

# Dev-only proxy target (used by vite.config.ts)
VITE_DEV_PROXY_TARGET=http://localhost:3001

# Runtime API base URL (used by fetch in the browser)
# - Recommended for dev: leave empty to use same-origin routes like /race/* and /bets (proxied)
# - If your backend is mounted under /api, set VITE_API_URL=/api
# - Recommended for prod: set to your backend origin, e.g. https://api.example.com
VITE_API_URL=

# Optional API token header added as: x-api-token: <token>
VITE_API_TOKEN=

# Run frontend without trying to reach the backend (no /race fetches, no WS connect)
# Set to 1/true to enable.
VITE_OFFLINE=

# Runtime websocket URL
# - Recommended for dev: leave unset to use ws(s)://<frontend-host>/ws (proxied)
# - Or set explicitly to your backend ws url, e.g. wss://api.example.com
# VITE_WS_URL=ws://localhost:3001

# If VITE_WS_URL is not set, WS URL is derived and this path is appended
VITE_WS_PATH=/ws

# Optional WS query params
VITE_WS_MODE=plain
VITE_WS_BINARY=
