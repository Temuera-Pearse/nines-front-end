# Frontend runtime config (Vite)
#
# Local development reaches the remote DigitalOcean race backend through Vite.

# Dev-only proxy target (used by vite.config.ts)
VITE_DEV_PROXY_TARGET=https://king-prawn-app-a39mi.ondigitalocean.app

# Keep runtime URLs relative so browser requests use the Vite dev proxy.
VITE_NINES_BACKEND_URL=

# Legacy alias supported by src/config/runtime.ts.
VITE_API_URL=

# Optional API token header added as: x-api-token: <token>
VITE_API_TOKEN=

# Run frontend without trying to reach the backend (no /race fetches, no WS connect)
# Set to 1/true to enable.
VITE_OFFLINE=

# Use the deployed WebSocket directly; proxying long-lived WS traffic through
# Vite can produce EPIPE errors when the upstream reconnects.
VITE_NINES_WS_URL=wss://king-prawn-app-a39mi.ondigitalocean.app

# Legacy alias supported by src/config/runtime.ts.
VITE_WS_URL=

# If no explicit WS URL is set, WS URL is derived and this path is appended.
VITE_WS_PATH=/ws

# Optional WS query params
VITE_WS_MODE=plain
VITE_WS_BINARY=

# Auth0 SPA configuration
VITE_AUTH0_DOMAIN=nines-dev.au.auth0.com
VITE_AUTH0_CLIENT_ID=ntLKlXXpZ2HEX6THUaAxUkcYU57MKQzs
VITE_AUTH0_AUDIENCE=https://nines-api.local
VITE_NINES_API_URL=http://localhost:3002
